flowchart TD
    S(["Start produktions_prompt(pfad)"]) --> O["Datei oeffnen, Zeilen lesen"]
    O --> H["Header-Zeile ueberspringen"]
    H --> INIT["summe_stueck = 0<br/>summe_aus = 0"]
    INIT --> L{"weitere Zeile?"}
    L -- "ja" --> P["Zeile splitten,<br/>Stueck und Ausschuss als int"]
    P --> ADD["summe_stueck += stueck<br/>summe_aus += ausschuss"]
    ADD --> L
    L -- "nein" --> Q["quote = summe_aus / summe_stueck * 100"]
    Q --> PR["Prompt-String mit<br/>Kontext + Kennzahlen + Format bauen"]
    PR --> E(["Ende: prompt zurueckgeben"])
