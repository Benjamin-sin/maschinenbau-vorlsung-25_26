flowchart TD
    S(["Start"]) --> P["XML mit ET.parse laden"]
    P --> L["Leere Liste 'zeilen'"]
    L --> FL{"Fuer jede<br/>produktionslinie"}
    FL -->|"ja"| FA{"Fuer jeden<br/>auftrag darunter"}
    FA -->|"ja"| D["Dict anlegen<br/>(linie_id, stueckzahl_produziert, ...)"]
    D --> APP["An 'zeilen' anhaengen"]
    APP --> FA
    FA -->|"fertig"| FL
    FL -->|"fertig"| DF["pd.DataFrame(zeilen)"]
    DF --> GB["groupby('linie_id')['stueckzahl_produziert'].sum()"]
    GB --> MX["idxmax() finden"]
    MX --> E(["beste_linie"])
