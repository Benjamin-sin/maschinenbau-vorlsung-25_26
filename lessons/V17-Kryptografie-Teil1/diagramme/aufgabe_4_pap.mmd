flowchart TD
    S(["Start: text, k"]) --> I["Schluessel umkehren:<br/>k_ent = (26 - k) % 26"]
    I --> R["Ergebnis = '' (leerer String)"]
    R --> F{"Fuer jedes Zeichen z<br/>in text"}
    F -- "ja" --> C{"z ist<br/>Grossbuchstabe A-Z?"}
    C -- "ja" --> V["pos = ord(z) - 65<br/>neu = (pos + k_ent) % 26<br/>z_neu = chr(neu + 65)"]
    C -- "nein" --> U["z_neu = z<br/>(unveraendert)"]
    V --> A["Ergebnis = Ergebnis + z_neu"]
    U --> A
    A --> F
    F -- "fertig" --> O["Ergebnis zurueckgeben"]
    O --> E(["Ende"])
